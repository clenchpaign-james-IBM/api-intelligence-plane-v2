# API Intelligence Plane - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# OpenSearch Configuration
# ============================================================================
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_SCHEME=http
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_VERIFY_CERTS=false

# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Primary LLM Provider (OpenAI, Anthropic, Azure, etc.)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.openai.com/v1

# Fallback LLM Provider (optional)
LLM_FALLBACK_PROVIDER=anthropic
LLM_FALLBACK_MODEL=claude-3-sonnet-20240229
LLM_FALLBACK_API_KEY=your-fallback-api-key-here

# LLM Configuration
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30

# ============================================================================
# Backend API Configuration
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# Frontend Configuration
# ============================================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_APP_NAME=API Intelligence Plane
VITE_APP_VERSION=1.0.0

# ============================================================================
# MCP Server Configuration
# ============================================================================
MCP_TRANSPORT=streamablehttp
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ============================================================================
# Demo Gateway Configuration
# ============================================================================
GATEWAY_PORT=8080
GATEWAY_NAME=Demo Gateway
GATEWAY_VERSION=1.0.0

# ============================================================================
# Scheduler Configuration
# ============================================================================
# Discovery job interval (minutes)
DISCOVERY_INTERVAL=5

# Metrics collection interval (minutes)
METRICS_INTERVAL=1

# Prediction generation interval (minutes)
PREDICTION_INTERVAL=15

# Security scanning interval (minutes)
SECURITY_SCAN_INTERVAL=60

# Optimization analysis interval (minutes)
OPTIMIZATION_INTERVAL=30

# ============================================================================
# TLS/SSL Configuration (FedRAMP 140-3 Compliance)
# ============================================================================
# Enable TLS 1.3 for backend server
TLS_ENABLED=false
TLS_CERT_FILE=/path/to/server-cert.pem
TLS_KEY_FILE=/path/to/server-key.pem
TLS_CA_FILE=/path/to/ca-cert.pem

# OpenSearch TLS Configuration
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_CLIENT_CERT=/path/to/opensearch-client-cert.pem
OPENSEARCH_CLIENT_KEY=/path/to/opensearch-client-key.pem
OPENSEARCH_CA_CERT=/path/to/opensearch-ca-cert.pem

# Client TLS Configuration (for external API calls)
CLIENT_CERT_FILE=/path/to/client-cert.pem
CLIENT_KEY_FILE=/path/to/client-key.pem
CLIENT_CA_FILE=/path/to/client-ca-cert.pem

# ============================================================================
# Security Configuration
# ============================================================================
# Secret key for encryption (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# JWT Configuration (for future authentication)
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_DISCOVERY=true
ENABLE_METRICS=true
ENABLE_PREDICTIONS=true
ENABLE_SECURITY_SCANNING=true
ENABLE_OPTIMIZATION=true
ENABLE_RATE_LIMITING=true
ENABLE_QUERY_INTERFACE=true

# ============================================================================
# Data Retention Configuration
# ============================================================================
# Metrics retention (days)
METRICS_RETENTION_DAYS=90

# Query history retention (days)
QUERY_RETENTION_DAYS=30

# Prediction retention (days)
PREDICTION_RETENTION_DAYS=180

# ============================================================================
# Performance Configuration
# ============================================================================
# Maximum concurrent API discoveries
MAX_CONCURRENT_DISCOVERIES=10

# Maximum concurrent security scans
MAX_CONCURRENT_SCANS=5

# Query timeout (seconds)
QUERY_TIMEOUT=5

# ============================================================================
# Monitoring & Observability
# ============================================================================
ENABLE_METRICS_EXPORT=true
METRICS_EXPORT_PORT=9090
ENABLE_TRACING=false
TRACING_ENDPOINT=http://localhost:4318

# ============================================================================
# Development Settings
# ============================================================================
DEBUG=false
TESTING=false
LOG_FORMAT=json